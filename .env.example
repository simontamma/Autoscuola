# ── Server ────────────────────────────────────────────────────
PORT=3000

# ── JWT ───────────────────────────────────────────────────────
# CAMBIA QUESTO VALORE IN PRODUZIONE con una stringa lunga e casuale
# Puoi generarne una con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=autoscuola_secret_cambia_in_produzione
JWT_EXPIRY=8h

# ── Frontend (CORS) ───────────────────────────────────────────
# URL del tuo frontend (es. http://localhost:5500 oppure https://tuodominio.it)
FRONTEND_URL=*
